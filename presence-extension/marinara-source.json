{
  "schemaVersion": 1,
  "type": "capability-package",
  "includeInMain": false,
  "processing": {
    "kind": "legacy-extension",
    "buildCommand": ["npm", "run", "build"]
  },
  "package": {
    "id": "presence-extension",
    "name": "Presence (Extension)",
    "description": "Tracks per-message character presence and temporarily filters prompt history during generation.",
    "engine": {
      "min": "2.3.0",
      "maxExclusive": "3.0.0"
    },
    "kind": ["agent"],
    "permissions": ["chat-read", "chat-write", "network", "storage", "ui"],
    "restartRequired": false
  }
}

