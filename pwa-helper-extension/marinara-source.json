{
  "schemaVersion": 1,
  "type": "capability-package",
  "includeInMain": false,
  "processing": {
    "kind": "legacy-extension",
    "buildCommand": ["npm", "run", "build"]
  },
  "package": {
    "id": "pwa-helper-extension",
    "name": "PWA Helper (Extension)",
    "description": "Keeps mobile and tablet screens awake while Marinara generation is running.",
    "engine": {
      "min": "2.3.0",
      "maxExclusive": "3.0.0"
    },
    "kind": ["agent"],
    "permissions": ["ui"],
    "restartRequired": false
  }
}

