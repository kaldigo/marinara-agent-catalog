{
  "schemaVersion": 1,
  "type": "capability-package",
  "includeInMain": true,
  "processing": {
    "kind": "package-build",
    "buildCommand": ["npm", "run", "build"],
    "outputDir": "dist/package",
    "sharedRoots": ["_mari-bridge"]
  },
  "package": {
    "id": "presence",
    "name": "Presence",
    "description": "Work-in-progress package-era character presence for Roleplay chats.",
    "kind": ["agent"],
    "permissions": ["agent-runtime", "chat-read", "chat-write", "prompt-context", "routes", "storage", "ui"],
    "restartRequired": true
  }
}
